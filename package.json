{
  "name": "resume-parser-job-matcher",
  "version": "1.0.0",
  "description": "Resume Parsing and Job Matching System without LLMs",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "demo": "node demo.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "setup": "npm install && mkdir -p database",
    "docker:build": "docker build -t resume-parser:latest .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/database:/app/database resume-parser:latest",
    "compose:up": "docker-compose up -d",
    "compose:down": "docker-compose down",
    "compose:logs": "docker-compose logs -f"
  },
  "keywords": [
    "resume-parser",
    "job-matching",
    "nlp",
    "rule-based"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "sqlite3": "^5.1.6",
    "pdf-parse": "^1.1.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "jest": "^29.5.0",
    "eslint": "^8.40.0"
  }
}
